{
  "manifest_version": 3,
  "name": "PDF Sentence Navigator",
  "version": "1.0.0",
  "description": "Navigate PDF sentences with Tab and Shift+Tab.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
